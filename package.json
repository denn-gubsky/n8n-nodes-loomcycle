{
	"name": "n8n-nodes-loomcycle",
	"version": "0.3.0",
	"description": "n8n community nodes for the loomcycle agentic runtime — design and operate loomcycle agents from n8n's visual builder. Sub-phase 2.2 extends the umbrella LoomCycle node with AgentDef / SkillDef / MCPServerDef substrate-admin resources.",
	"keywords": [
		"n8n-community-node-package",
		"n8n",
		"loomcycle",
		"agentic",
		"llm",
		"mcp",
		"agent"
	],
	"license": "Apache-2.0",
	"homepage": "https://github.com/denn-gubsky/n8n-nodes-loomcycle#readme",
	"author": {
		"name": "Dennis Gubsky"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/denn-gubsky/n8n-nodes-loomcycle.git"
	},
	"bugs": {
		"url": "https://github.com/denn-gubsky/n8n-nodes-loomcycle/issues"
	},
	"main": "index.js",
	"engines": {
		"node": ">=20.15"
	},
	"scripts": {
		"build": "tsc -p tsconfig.build.json && gulp build:icons",
		"build:icons": "gulp build:icons",
		"dev": "tsc --watch",
		"typecheck": "tsc --noEmit",
		"format": "prettier --write \"**/*.{ts,json,md,yml}\"",
		"lint": "eslint . --ext .ts",
		"lintfix": "eslint . --ext .ts --fix",
		"prepublishOnly": "npm run build && eslint . --ext .ts -c .eslintrc.prepublish.js",
		"test": "vitest run",
		"test:watch": "vitest"
	},
	"files": [
		"dist"
	],
	"n8n": {
		"n8nNodesApiVersion": 1,
		"credentials": [
			"dist/credentials/LoomCycleApi.credentials.js"
		],
		"nodes": [
			"dist/nodes/LoomCycle/LoomCycle.node.js"
		]
	},
	"dependencies": {
		"@loomcycle/client": "^0.9.2"
	},
	"peerDependencies": {
		"n8n-workflow": ">=1.82.0 <2.0.0"
	},
	"devDependencies": {
		"@types/node": "^20.14.0",
		"@typescript-eslint/eslint-plugin": "^7.18.0",
		"@typescript-eslint/parser": "^7.18.0",
		"@vitest/coverage-v8": "^3.0.0",
		"eslint": "^8.57.0",
		"eslint-plugin-n8n-nodes-base": "^1.16.0",
		"gulp": "^5.0.0",
		"n8n-workflow": "^1.82.0",
		"prettier": "^3.3.0",
		"typescript": "^5.4.0",
		"vitest": "^3.0.0"
	}
}
