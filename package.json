{
	"name": "@loomcycle/n8n-nodes-loomcycle",
	"version": "3.11.0",
	"publishConfig": {
		"access": "public"
	},
	"description": "Community n8n nodes for the loomcycle agentic runtime. Design and operate loomcycle agents from n8n's visual builder: 22 nodes — 18 action nodes (Run, Memory, Channel, Agent Definition, Skill Definition, MCP Server, Schedule, Hook, Webhook, A2A Agent, A2A Server Card, Interruption, LLM, Memory Backend, Operator Token, Snapshot, Volume, Path), 3 triggers, and a Chat Model sub-node (routes the AI Agent's LLM calls through loomcycle's gateway, built on @n8n/ai-node-sdk). Zero runtime dependencies. Pairs with loomcycle ≥ v0.9.2 (Schedule + per-tool credentials require ≥ v0.12.x; Webhook + A2A require ≥ v0.14.x; interactive run steering requires ≥ v1.1.1; Volume requires ≥ v1.1; Path requires ≥ v1.4).",
	"keywords": [
		"n8n-community-node-package",
		"n8n",
		"loomcycle",
		"agentic",
		"llm",
		"mcp",
		"agent"
	],
	"license": "MIT",
	"homepage": "https://github.com/denn-gubsky/n8n-nodes-loomcycle#readme",
	"author": {
		"name": "Dennis Gubsky",
		"email": "denn@loomcycle.dev"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/denn-gubsky/n8n-nodes-loomcycle.git"
	},
	"bugs": {
		"url": "https://github.com/denn-gubsky/n8n-nodes-loomcycle/issues"
	},
	"main": "index.js",
	"engines": {
		"node": ">=20.15"
	},
	"scripts": {
		"build": "node scripts/build.cjs && gulp build:icons",
		"build:icons": "gulp build:icons",
		"dev": "tsc --watch",
		"typecheck": "tsc --noEmit",
		"format": "prettier --write \"**/*.{ts,json,md,yml}\"",
		"lint": "eslint . --ext .ts",
		"lintfix": "eslint . --ext .ts --fix",
		"prepublishOnly": "npm run build && eslint . --ext .ts -c .eslintrc.prepublish.js",
		"test": "vitest run",
		"test:watch": "vitest"
	},
	"files": [
		"dist"
	],
	"n8n": {
		"n8nNodesApiVersion": 1,
		"credentials": [
			"dist/credentials/LoomCycleApi.credentials.js"
		],
		"nodes": [
			"dist/nodes/LoomCycleRun/LoomCycleRun.node.js",
			"dist/nodes/LoomCycleMemory/LoomCycleMemory.node.js",
			"dist/nodes/LoomCycleChannel/LoomCycleChannel.node.js",
			"dist/nodes/LoomCycleAgentDef/LoomCycleAgentDef.node.js",
			"dist/nodes/LoomCycleSkillDef/LoomCycleSkillDef.node.js",
			"dist/nodes/LoomCycleMcpServerDef/LoomCycleMcpServerDef.node.js",
			"dist/nodes/LoomCycleSchedule/LoomCycleSchedule.node.js",
			"dist/nodes/LoomCycleHook/LoomCycleHook.node.js",
			"dist/nodes/LoomCycleWebhook/LoomCycleWebhook.node.js",
			"dist/nodes/LoomCycleA2aAgent/LoomCycleA2aAgent.node.js",
			"dist/nodes/LoomCycleA2aServerCard/LoomCycleA2aServerCard.node.js",
			"dist/nodes/LoomCycleInterruption/LoomCycleInterruption.node.js",
			"dist/nodes/LoomCycleLlm/LoomCycleLlm.node.js",
			"dist/nodes/LoomCycleMemoryBackend/LoomCycleMemoryBackend.node.js",
			"dist/nodes/LoomCycleOperatorToken/LoomCycleOperatorToken.node.js",
			"dist/nodes/LoomCycleSnapshot/LoomCycleSnapshot.node.js",
			"dist/nodes/LoomCycleVolume/LoomCycleVolume.node.js",
			"dist/nodes/LoomCyclePath/LoomCyclePath.node.js",
			"dist/nodes/LoomCycleRunCompleted/LoomCycleRunCompleted.node.js",
			"dist/nodes/LoomCycleChannelMessage/LoomCycleChannelMessage.node.js",
			"dist/nodes/LoomCycleInterruptPending/LoomCycleInterruptPending.node.js",
			"dist/nodes/LoomCycleChatModel/LoomCycleChatModel.node.js"
		]
	},
	"peerDependencies": {
		"n8n-workflow": "*"
	},
	"devDependencies": {
		"@loomcycle/client": "^1.4.0",
		"@n8n/ai-node-sdk": "^0.13.1",
		"@types/node": "^20.14.0",
		"@typescript-eslint/eslint-plugin": "^7.18.0",
		"@typescript-eslint/parser": "^7.18.0",
		"@vitest/coverage-v8": "^3.0.0",
		"esbuild": "^0.28.0",
		"eslint": "^8.57.0",
		"eslint-plugin-n8n-nodes-base": "^1.16.0",
		"gulp": "^5.0.0",
		"n8n-workflow": "^1.82.0",
		"prettier": "^3.3.0",
		"typescript": "^5.4.0",
		"vitest": "^3.0.0"
	}
}
